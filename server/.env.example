# UPS Orchestrator Server Configuration
UPS_SERVER_PORT=8787

# Shared secret token for authentication between server and desktop agents
UPS_SHARED_TOKEN=change-me-secret-token

# Directory where state files will be stored
UPS_STATE_DIR=./.runtime-state

# Timeout for short requests (e.g. status check) in seconds
UPS_REQUEST_TIMEOUT_SHORT=5
# Timeout for long requests (e.g. command push) in seconds
UPS_REQUEST_TIMEOUT_LONG=30
# Max age for state freshness in seconds
UPS_STATE_MAX_AGE=300
# Interval for polling UPS devices in seconds
UPS_POLL_INTERVAL=30

# Path to UPS devices configuration file (relative to server/ or absolute)
UPS_CONFIG_FILE=ups_config.yml

# UPS device ID as defined in ups_config.yml — used by NUT event scripts (upssched-cmd)
UPS_DEVICE_ID=main-ups
