# UPS Orchestrator Desktop Agent Configuration

# Shared secret token (must match the server's token)
UPS_SHARED_TOKEN=change-me-secret-token

# Base URL of the Orchestrator Server
UPS_SERVER_BASE=http://192.168.50.10:8787


# Port where the Desktop Agent listens
UPS_AGENT_PORT=8788
# Timeout for UI prompts in seconds
UPS_UI_PROMPT_TIMEOUT=5
# Fast request timeout (e.g. shutting down/suspending) in seconds
UPS_REQUEST_TIMEOUT_FAST=2
# Normal request timeout (e.g. state push) in seconds
UPS_REQUEST_TIMEOUT_NORMAL=5
# Time to wait for network after wake-up in seconds
UPS_NETWORK_WAIT_TIMEOUT=5

# Suspend mechanism reliability configuration
UPS_SUSPEND_MAX_RETRIES=3
UPS_SUSPEND_RETRY_DELAY=5
